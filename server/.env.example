# Client Environment Variables (create .env in client folder)
# For local development, create client/.env with:
# REACT_APP_API_URL=http://localhost:5000
# 
# For production/deployment, create client/.env with:
# REACT_APP_API_URL=https://your-backend.onrender.com

# Server Environment Variables (for deployment)
GROQ_API_KEY=your_groq_api_key
SARVAM_API_KEY=your_sarvam_api_key
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
DATABASE_URL=your_postgres_connection_string

# Port (default 5000 for local)
PORT=5000
